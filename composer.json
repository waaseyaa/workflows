{
    "name": "waaseyaa/workflows",
    "description": "Content moderation and editorial workflow states for Waaseyaa",
    "type": "library",
    "license": "GPL-2.0-or-later",
    "repositories": [
        {
            "type": "path",
            "url": "../access"
        },
        {
            "type": "path",
            "url": "../audit"
        },
        {
            "type": "path",
            "url": "../config"
        },
        {
            "type": "path",
            "url": "../entity"
        },
        {
            "type": "path",
            "url": "../entity-storage"
        },
        {
            "type": "path",
            "url": "../foundation"
        },
        {
            "type": "path",
            "url": "../groups"
        },
        {
            "type": "path",
            "url": "../relationship"
        },
        {
            "type": "path",
            "url": "../database-legacy"
        },
        {
            "type": "path",
            "url": "../node"
        }
    ],
    "require": {
        "php": ">=8.5",
        "waaseyaa/access": "^0.1.0-alpha.263",
        "waaseyaa/audit": "^0.1.0-alpha.263",
        "waaseyaa/config": "^0.1.0-alpha.263",
        "waaseyaa/entity": "^0.1.0-alpha.263",
        "waaseyaa/entity-storage": "^0.1.0-alpha.263",
        "waaseyaa/foundation": "^0.1.0-alpha.263",
        "waaseyaa/groups": "^0.1.0-alpha.263",
        "waaseyaa/relationship": "^0.1.0-alpha.263"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5",
        "waaseyaa/database-legacy": "^0.1.0-alpha.263",
        "waaseyaa/node": "^0.1.0-alpha.263"
    },
    "autoload": {
        "psr-4": {
            "Waaseyaa\\Workflows\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Waaseyaa\\Workflows\\Tests\\": "tests/"
        }
    },
    "extra": {
        "waaseyaa": {
            "providers": [
                "Waaseyaa\\Workflows\\WorkflowServiceProvider"
            ]
        },
        "branch-alias": {
            "dev-main": "0.1.x-dev",
            "dev-develop/v1.1": "0.1.x-dev"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "config": {
        "sort-packages": true
    }
}
